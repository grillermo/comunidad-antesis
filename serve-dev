#!/usr/bin/env bash
set -euo pipefail

# Load environment variables
set -a
[ -f .env ] && . .env
set +a

SESSION="comunidad-antesis"
RAILS_PORT="${RAILS_PORT:-3000}"

# Kill existing session if any
tmux kill-session -t "$SESSION" 2>/dev/null || true

# Create session with first pane
tmux new-session -d -s "$SESSION" -n main

# Split into 3 panes
tmux split-window -h -t "$SESSION"
tmux split-window -v -t "$SESSION"

# Pane 1: Rails server
tmux send-keys -t "$SESSION:main.1" "source .env 2>/dev/null; bin/rails server -p $RAILS_PORT -b 0.0.0.0" C-m

# Pane 2: Vite dev server (HMR, including RailsAdmin at /antesis-admin)
tmux send-keys -t "$SESSION:main.2" "source .env 2>/dev/null; bin/vite dev" C-m

# Pane 3: Solid Queue worker
tmux send-keys -t "$SESSION:main.3" "source .env 2>/dev/null; RAILS_LOG_TO_STDOUT=1 bin/jobs" C-m

# Attach to session
tmux attach -t "$SESSION"
