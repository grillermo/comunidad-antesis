#!/usr/bin/env bash
set -euo pipefail

# Load environment variables
set -a
[ -f .env ] && . .env
set +a

export RAILS_ENV="${RAILS_ENV:-production}"
export RAILS_LOG_TO_STDOUT="${RAILS_LOG_TO_STDOUT:-1}"
export RAILS_SERVE_STATIC_FILES="${RAILS_SERVE_STATIC_FILES:-true}"
export RAILS_PORT="${RAILS_PORT:-4020}"

# Build assets (assets:precompile runs Vite, including RailsAdmin at /antesis-admin)
bin/rails assets:precompile

# Run the three processes in parallel, interleaved to this terminal.
# --color           : give each process its own colour.
# --colsep/--tagstring : tab-split "label<TAB>command"; tag each line with label.
# --line-buffer     : stream output line-by-line (no per-job buffering).
# --halt now,done=1 : if any process exits, kill the rest and stop.
parallel --color --line-buffer --colsep '\t' --tagstring '{1}' --halt now,done=1 '{2}' ::: \
  'rails	bin/rails server -p "$RAILS_PORT" -b 0.0.0.0' \
  'jobs	bin/jobs' \
  'ssr	bin/vite ssr'
